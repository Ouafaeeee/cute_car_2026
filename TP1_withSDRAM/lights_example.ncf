<?xml version="1.0" encoding="UTF-8"?>
<nios2_config version="1.0">
    <system>
        <system_info filepath="true">nios_system.sopcinfo</system_info>
        <system_sof filepath="true">output_files\lights.sof</system_sof>
        <system_jdi filepath="true"/>
        <cable>null</cable>
        <processor JTAGHubInstanceID="0">nios2_processor</processor>
        <terminal JTAGHubInstanceID="0">jtag_uart</terminal>
    </system>
</nios2_config>
